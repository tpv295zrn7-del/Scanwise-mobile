{
  "expo": {
    "name": "ScanWise",
    "slug": "scanwise-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/app-icon.png",
    "scheme": "scanwise",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "ScanWise uses your camera to scan product barcodes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/app-icon.png",
        "backgroundColor": "#10B981"
      },
      "permissions": ["CAMERA"]
    }
  }
}
