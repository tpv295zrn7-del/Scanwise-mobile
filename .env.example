# Environment Variables — Copy to .env and fill in values
# DO NOT commit .env to version control

# ── Apple / iOS ──────────────────────────────────────────
# Your 10-character Apple Team ID (found in developer.apple.com)
APPLE_TEAM_ID=XXXXXXXXXX

# Apple App Store Connect API Key ID
APPLE_KEY_ID=XXXXXXXXXX

# ── Android / Play Store ─────────────────────────────────
# JSON key for Play Store service account (full JSON content as a single line)
PLAY_STORE_JSON_KEY={}

# ── Android Keystore ─────────────────────────────────────
# Base64-encoded keystore file (used in CI — generate with:
#   base64 -i android/app/keystore/scanwise.keystore | pbcopy)
KEYSTORE_BASE64=

# Keystore / key passwords and alias
KEYSTORE_PASS=your_keystore_password
KEY_ALIAS=scanwise
KEY_PASS=your_key_password

# ── Backend API ──────────────────────────────────────────
API_BASE_URL=https://api.scanwise.com
